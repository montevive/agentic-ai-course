# Copy this file to .env and fill in ONE of the two options below.

# =============================================================================
# Option 1 (recommended for the course): Montevive LLM proxy
# =============================================================================
# Set this single key and every exercise routes through https://llm.montevive.ai.
# The proxy only allows the course models, so there is no risk of accidentally
# using an expensive model, and it shares one daily budget. You will be given
# this key at the start of the course. When it is set, the three provider keys
# below are ignored (the same key is used for all providers).
LITELLM_API_KEY=

# =============================================================================
# Option 2: no proxy - your own provider keys, calling the providers directly
# =============================================================================
# Used only when LITELLM_API_KEY above is empty. One key is enough to start;
# each exercise indicates which provider it needs.

# Anthropic (recommended as the primary provider) - https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (only needed for the OpenAI Agents SDK block) - https://platform.openai.com/
OPENAI_API_KEY=

# Google Gemini - https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional (Session 3, traceability) - https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
